{
	"name": "web",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite --clearScreen false",
		"build": "tsc && vite build",
		"type-check": "tsc --noEmit",
		"preview": "vite preview --port 5173",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:update-snapshots": "playwright test --update-snapshots --grep @visual"
	},
	"dependencies": {
		"@repo/buy-box": "*",
		"@repo/cart": "*",
		"@repo/product": "*",
		"react": "19.2.6",
		"react-dom": "19.2.6"
	},
	"devDependencies": {
		"@playwright/cli": "0.1.13",
		"@playwright/test": "1.60.0",
		"@repo/config": "*",
		"@tailwindcss/vite": "4.3.0",
		"@types/node": "25.9.1",
		"@types/react": "19.2.15",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "6.0.2",
		"puppeteer": "24.15.0",
		"tailwindcss": "4.3.0",
		"typescript": "6.0.3",
		"vite": "8.0.13"
	}
}
