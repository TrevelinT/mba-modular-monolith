{
	"private": true,
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"format-and-lint": "biome check .",
		"format-and-lint:fix": "biome check . --write",
		"type-check": "turbo run type-check",
		"test": "turbo run test",
		"test:watch": "turbo run test:watch",
		"test-coverage": "npm run test && npm run test-coverage:merge && npm run test-coverage:report",
		"test-coverage:merge": "turbo run //#merge-coverage",
		"test-coverage:report": "turbo run //#report-coverage",
		"merge-coverage": "node scripts/merge-coverage.mjs",
		"report-coverage": "nyc report -t coverage/merged --report-dir coverage/report --reporter=html --reporter=text"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@testing-library/jest-dom": "6.9.1",
		"@testing-library/react": "16.3.0",
		"@vitest/coverage-v8": "3.2.4",
		"jsdom": "26.1.0",
		"nyc": "17.1.0",
		"turbo": "2.9.14",
		"vitest": "3.2.4"
	},
	"name": "with-vite-react",
	"engines": {
		"node": "24.15.0",
		"npm": "11.12.1"
	},
	"packageManager": "npm@11.12.1",
	"workspaces": [
		"apps/*",
		"packages/*"
	]
}
